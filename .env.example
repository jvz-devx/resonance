# Discord bot token (required)
DISCORD_TOKEN=your_discord_bot_token_here

# Redis URL for queue persistence (optional — bot works without it)
REDIS_URL=redis://127.0.0.1:6379

# Auto-disconnect timeout in seconds (default: 300 = 5 minutes)
IDLE_TIMEOUT_SECS=300

# PO token server URL for YouTube bot detection bypass (default: http://pot-server:4416)
POT_SERVER_URL=http://pot-server:4416

# Log level configuration
RUST_LOG=info,resonance=debug
